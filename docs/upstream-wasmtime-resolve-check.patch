+
+/// A check that will be called for each DNS hostname resolution a
+/// guest requests via `wasi:sockets/ip-name-lookup::resolve-addresses`.
+///
+/// Mirrors [`SocketAddrCheck`] (the connect-side analog), but
+/// applied at the DNS resolution boundary. Returning `true` permits
+/// the resolution and lets the upstream resolver proceed; returning
+/// `false` denies the resolve call with
+/// `ErrorCode::PermanentResolverFailure`.
+///
+/// The closure is fired from
+/// `wasmtime-wasi-45.0.3/src/p2/ip_name_lookup.rs:21-39` (the
+/// upstream `Host for WasiSocketsCtxView::resolve_addresses` impl)
+/// before the kernel resolver runs, so a host that wants to gate
+/// raw-socket egress on observed DNS resolutions can populate a
+/// per-Network cache here and check it in the connect-side
+/// `SocketAddrCheck` closure.
+#[derive(Clone)]
+pub(crate) struct ResolveAddressCheck(
+    Arc<
+        dyn Fn(String, SocketAddrUse) -> Pin<Box<dyn Future<Output = bool> + Send + Sync>>
+            + Send
+            + Sync,
+    >,
+);
+
+impl ResolveAddressCheck {
+    pub(crate) fn new<F>(f: F) -> Self
+    where
+        F: Fn(String, SocketAddrUse) -> Pin<Box<dyn Future<Output = bool> + Send + Sync>>
+            + Send
+            + Sync
+            + 'static,
+    {
+        Self(Arc::new(f))
+    }
+
+    pub(crate) async fn check(
+        &self,
+        host: String,
+        use_: SocketAddrUse,
+    ) -> std::io::Result<()> {
+        if (self.0)(host, use_).await {
+            Ok(())
+        } else {
+            Err(std::io::Error::new(
+                std::io::ErrorKind::PermissionDenied,
+                "An address was not permitted by the resolve address check.",
+            ))
+        }
+    }
+}
+
+impl Default for ResolveAddressCheck {
+    fn default() -> Self {
+        Self(Arc::new(|_, _| Box::pin(async { true })))
+    }
+}

