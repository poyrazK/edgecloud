# edgeCloud local development secrets.
# Copy this file to `.env` once:   cp .env.example .env
# `.env` is gitignored. Do not commit your edited copy.
# These values are for local development only. The control plane
# binary rejects the dev default `edgecloud` at startup as a
# fail-closed guard (see edge-control-plane/internal/config/config.go).

POSTGRES_USER=edgecloud
POSTGRES_PASSWORD=edgecloud   # dev-only — override before any non-local use
POSTGRES_DB=edgecloud

# The control plane reads DATABASE_* (separate namespace from the
# POSTGRES_* compose vars). Both names resolve to the same value in
# practice; keep them in sync if you change one.
DATABASE_USER=edgecloud
DATABASE_PASSWORD=edgecloud
DATABASE_NAME=edgecloud
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_SSLMODE=disable