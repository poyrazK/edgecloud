# edgeCloud production environment variables.
# Copy once:    cp .env.prod.example .env.prod
# The copied `.env.prod` is gitignored — never commit it.
#
# Every variable in this file is read by at least one of the three
# services bundled in docker-compose.prod.yml. `set -a; . .env.prod`
# semantics (mirror the dev Makefile pattern from PR #670).
#
# All values below are placeholders. Before any non-local use, every
# one must be overridden. The Makefile `prod-up` target walks each
# `${VAR:?error}` form in docker-compose.prod.yml and fails if the
# variable is unset OR equals a known dev placeholder.
#
# Generate each secret with the openssl/pwgen command documented
# inline. The control plane's `validateDBPassword`
# (edge-control-plane/internal/config/config.go) enforces a 16-byte
# minimum length floor for DATABASE_PASSWORD — anything shorter
# causes the API to refuse to start.

# ── Postgres (matches docker-compose.yml's POSTGRES_* + DATABASE_*) ──
# DATABASE_PASSWORD must be ≥ 16 bytes (issue #626 / validateDBPassword).
# These two names are aliases — keep them in sync.
POSTGRES_USER=edgecloud
POSTGRES_PASSWORD=replace-me-with-`openssl rand -base64 24`-output   # ≥ 16B
POSTGRES_DB=edgecloud

DATABASE_USER=edgecloud
DATABASE_PASSWORD=replace-me-with-`openssl rand -base64 24`-output   # ≥ 16B
DATABASE_NAME=edgecloud
DATABASE_HOST=postgres            # service name in docker-compose.prod.yml
DATABASE_PORT=5432
DATABASE_SSLMODE=disable          # use `require` for TLS-only Postgres

# ── Region / identity ────────────────────────────────────────────────
APP_REGION=edge-prod
REGION=edge-prod                  # WORKER_ID / REGION — same value
WORKER_ID=w_prod_main
WORKER_TENANT_ID=*                # defaults to "*" per edge-worker/src/config.rs; set explicitly to one tenant for prod
EDGE_WORKER_ADDR=worker.example.com:443   # the externally-routable address of THIS worker host:port

# ── JWT + internal auth ──────────────────────────────────────────────
# JWT_SECRET: HS256 signing key for CP-issued tenant API keys.
# Generate: openssl rand -base64 48 (a 64-char string)
JWT_SECRET=replace-me-with-`openssl rand -base64 48`-output    # ≥ 32B recommended

# EDGE_INTERNAL_TOKEN: shared secret between CP and ingress for
# `/api/v1/internal/*` (read by edge-ingress for traffic + rate-limits
# + quota + secrets admin). Generate: openssl rand -hex 32
EDGE_INTERNAL_TOKEN=replace-me-with-`openssl rand -hex 32`-output

# BOOTSTRAP_SECRET: shared secret between CP and worker for the
# three-phase JWT bootstrap handshake (issue #430). Generate:
# openssl rand -hex 32. The worker uses this to mint an initial
# per-worker HS256 secret at boot.
BOOTSTRAP_SECRET=replace-me-with-`openssl rand -hex 32`-output

# ── NATS ──────────────────────────────────────────────────────────────
# Single-node compose pins NATS_REPLICAS=1 (compose-side env);
# a multi-node NATS cluster in production would set this to the
# number of nodes.
NATS_URL=nats://nats:4222
NATS_REPLICAS=1

# ── Artifact signing (issue #307 PR2) ────────────────────────────────
# EDGE_REQUIRE_SIGNATURE defaults to true in edge-worker/src/config.rs:403.
# The worker fails to boot without a keyring file mounted at the
# signing-keyring path. Generate a keypair once and re-use across
# all workers + the CP:
#
#   openssl rand -hex 32 > ./secrets/signing-seed.kidN
#
# The keyring file format is `<kid> = <32-byte-hex-seed>` per line —
# same format edge-control-plane/internal/signing/keyring.go and the
# worker read. Example two-line keyring (mock):
#
#   EDGE_SIGNING_KEY_ID=k1
#   EDGE_SIGNING_KEYRING=k1=$(head -c 32 /dev/urandom | xxd -p -c 64)
#
# Or, with a file (recommended for production):
#
#   EDGE_SIGNING_KEY_ID=k1
#   EDGE_SIGNING_KEYRING_PATH=/run/secrets/signing-keyring
#
# /run/secrets/signing-keyring in the worker container is bind-mounted
# from ./secrets/signing-keyring in the compose file. The file should
# be mode 0600, owned by the worker uid 1001.
EDGE_REQUIRE_SIGNATURE=true
EDGE_SIGNING_KEY_ID=k1
EDGE_SIGNING_KEYRING=k1=$(head -c 32 /dev/urandom | xxd -p -c 64)   # inline for demo; replace with keyring file in prod

# ── Worker observability ─────────────────────────────────────────────
# METRICS_AUTH_TOKEN: bearer for the /metrics endpoint. Empty value
# causes the worker to fail-closed 401 on every request
# (issue #49 / edge-worker/src/metrics_server.rs).
METRICS_AUTH_TOKEN=replace-me-with-`openssl rand -hex 32`-output

# ── Edge-migrate / wasm2cwasm (CP subprocesses) ──────────────────────
# Both binaries are baked into the CP image (default paths). Override
# only if running a custom CP build.
EDGE_MIGRATE_PATH=/usr/local/bin/edge-migrate
EDGE_WASM2CWASM_PATH=/usr/local/bin/wasm2cwasm

# ── Caddy admin auth ────────────────────────────────────────────────
# CADDY_ADMIN_TOKEN is the bearer token the ingress sends to Caddy's
# `/load` endpoint. Generate: openssl rand -hex 32.
# It MUST match the value baked into docker-compose.prod/caddy.json
# (`docker-compose.prod/caddy.local.json` after Makefile substitution).
CADDY_ADMIN_TOKEN=replace-me-with-`openssl rand -hex 32`-output

# ── TLS certs (mounted into the ingress container at /etc/caddy/tls) ─
# The ingress uses these to terminate TLS for <tenant>-<app>.edgecloud.dev
# hosts. For production, mount from a secret manager or copy from
# cert-manager into ./tls/cert.pem and ./tls/key.pem.
TLS_CERT_FILE=/etc/caddy/tls/cert.pem
TLS_KEY_FILE=/etc/caddy/tls/key.pem

# ── Tuning knobs (defaults are fine for most installs) ───────────────
# Worker:
EDGE_PORT_POOL_SIZE=100          # EDGE_PORT_POOL_SIZE; [1, 65535]; issue #641
APP_MAX_MEMORY_MB=256            # APP_MAX_MEMORY_MB
EDGE_HEALTH_CHECK_TIMEOUT_SECS=60
EDGE_WORKER_SYNC_THRESHOLD_SECS=60

# Ingress:
QUOTA_FETCH_INTERVAL=30s         # QUOTA_FETCH_INTERVAL; issue #420
RATE_LIMIT_FETCH_INTERVAL=60s
DOMAIN_POLL_INTERVAL=30s
