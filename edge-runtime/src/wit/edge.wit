package edge:cloud@0.2.0;

interface streams {
  // Why a shared interface: both http-client and http-server need the same
  // resource shapes. Sharing them via `use` avoids duplicate type definitions
  // and the cross-interface compatibility shim that would require.
  //
  // Resource methods are sync at the WIT boundary; the host bridges to async
  // via tokio::runtime::Handle::current().block_on(...) with a 5s timeout.
  // EOF is signaled by stream-error::closed on incoming::read-chunk.
  // finish() is the explicit end-of-stream signal on outgoing; Drop on the
  // host-side stream value is the cancellation backstop for guest abandonment.

  variant stream-error {
    cancelled,
    closed,
    io(string),
  }

  // host -> guest read direction (e.g. response body, large request body).
  resource incoming {
    // Read the next chunk. The host delivers the chunk at whatever size the
    // producer placed on the channel (bounded by the host's backpressure
    // buffer — default 8 chunks at the producer's natural chunk size). The
    // `max-bytes` parameter is ADVISORY and MAY be ignored by the host;
    // chunk-splitting is not implemented in v1. EOF is signaled by
    // `stream-error::closed`.
    read-chunk: func(max-bytes: u32) -> result<list<u8>, stream-error>;
    cancel: func();
  }

  // guest -> host write direction (e.g. streaming request body, streaming response body).
  resource outgoing {
    // Constructor the guest calls to obtain a fresh outgoing stream handle.
    // The host returns a Resource<Outgoing> backed by a bounded mpsc sender.
    constructor();
    write-chunk: func(bytes: list<u8>) -> result<_, stream-error>;
    finish: func() -> result<_, stream-error>;
  }
}

interface http-client {
  use streams.{incoming, outgoing, stream-error};

  // Request body: guest produces (none, buffered bytes, or outgoing stream).
  // Response body: host produces (none, buffered bytes, or incoming stream).
  // Two distinct variants make the direction explicit at the type level.
  variant request-body-source {
    none,
    buffered(list<u8>),
    chunked(outgoing),
  }
  variant response-body-source {
    none,
    buffered(list<u8>),
    chunked(incoming),
  }

  record trace-context {
    traceparent: string,
    tracestate: option<string>,
  }

  record request {
    method: string,
    url: string,
    headers: list<tuple<string, string>>,
    body: request-body-source,
    timeout-ms: option<u64>,
    trace-context: option<trace-context>,
  }

  record response {
    status: u16,
    headers: list<tuple<string, string>>,
    body: response-body-source,
    error: option<string>,
  }

  fetch: func(req: request) -> option<response>;
}

interface kv-store {
  get: func(key: string) -> option<list<u8>>;
  set: func(key: string, value: list<u8>, ttl-secs: option<u32>);
  delete: func(key: string);
  list-keys: func(prefix: string) -> list<string>;
  get-many: func(keys: list<string>) -> list<option<list<u8>>>;
  set-many: func(items: list<tuple<string, list<u8>, option<u32>>>);
  delete-many: func(keys: list<string>);
  exists: func(key: string) -> bool;
  clear: func();
}

interface cache {
  get: func(key: string) -> option<list<u8>>;
  set: func(key: string, value: list<u8>, ttl-secs: option<u32>);
  delete: func(key: string);
  clear: func();
  size: func() -> u32;
  exists: func(key: string) -> bool;
  list-keys: func(prefix: string) -> list<string>;
  get-many: func(keys: list<string>) -> list<option<list<u8>>>;
  set-many: func(items: list<tuple<string, list<u8>, option<u32>>>);
  delete-many: func(keys: list<string>);
}

interface observe {
  enum log-level {
    error,
    warn,
    info,
    debug,
    trace,
  }

  record log-record {
    timestamp-ms: u64,
    level: log-level,
    message: string,
    labels: list<tuple<string, string>>,
  }

  increment-counter: func(name: string, labels: list<tuple<string, string>>);
  record-gauge: func(name: string, value: f64, labels: list<tuple<string, string>>);
  record-histogram: func(name: string, value: f64, labels: list<tuple<string, string>>);
  emit-log: func(level: string, message: string, labels: list<tuple<string, string>>);
  emit-log-record: func(r: log-record);
}

interface time {
  now: func() -> u64;
  sleep: func(duration-ms: u64);
  resolution: func() -> u64;
}

interface scheduling {
  schedule-once: func(delay-ms: u64, payload: list<u8>) -> string;
  schedule-repeating: func(interval-ms: u64, payload: list<u8>) -> string;
  cancel-scheduled: func(id: string);
}

interface process {
  get-env: func(key: string) -> option<string>;
  get-all-env: func() -> list<tuple<string, string>>;
  get-args: func() -> list<string>;
  get-cwd: func() -> result<string, string>;
  exit: func(code: u32);
}

interface networking {
  resolve: func(hostname: string) -> list<string>;
}

interface http-server {
  use streams.{incoming, outgoing, stream-error};

  variant body-source {
    none,
    buffered(list<u8>),
    chunked(incoming),
  }

  record trace-context {
    traceparent: string,
    tracestate: option<string>,
  }

  record incoming-request {
    id: u64,
    method: string,
    path: string,
    query: option<string>,
    headers: list<tuple<string, string>>,
    body: body-source,
    trace: option<trace-context>,
    // Inbound body framing accepted by the host:
    // - Content-Length declared: body is buffered or streamed per the
    //   host's `stream_threshold`.
    // - Transfer-Encoding: chunked: body is decoded into the body-source.
    //   Per-chunk size is capped at the host's `max_body_size`. Trailers
    //   are read and discarded in v1.
    // - Neither (e.g. GET): body is empty.
    // Per RFC 7230 §3.3.3, when both Content-Length and TE: chunked are
    // present, TE wins and CL is ignored.
  }

  // Buffered response — existing call. Body is fully delivered.
  respond: func(req-id: u64, status: u16, headers: list<tuple<string, string>>, body: list<u8>) -> result<_, string>;
  // Streaming response — Content-Length is REQUIRED in headers and must be
  // a valid non-negative integer. Compression (Content-Encoding) is NOT
  // supported on this path in v1; use `respond` for pre-compressed bodies.
  // The host drains the outgoing stream and writes chunks with
  // timeout_at(deadline, write_all). Chunked transfer encoding is not
  // implemented in v1; deferred to v2. The host strips hop-by-hop and
  // host-reserved headers (Connection, Keep-Alive, Proxy-*, TE, Trailer,
  // Transfer-Encoding, Upgrade, Date, Server) from the guest's set.
  respond-stream: func(req-id: u64, status: u16, headers: list<tuple<string, string>>, body-stream: outgoing) -> result<_, string>;

  start: func(port: u16, host: option<string>) -> result<_, string>;
  shutdown: func();
  get-assigned-port: func() -> u16;
  poll: func() -> result<option<incoming-request>, string>;
  stop: func();
}

world edge-runtime {
  import http-client;
  import networking;
  import kv-store;
  import cache;
  import observe;
  import time;
  import scheduling;
  import process;
  import http-server;
}
